{
    "list": {
        "nextKeymap": "<C-n>",
        "previousKeymap": "<C-p>"
    },
    "languageserver": {
        "golang": {
            "command": "go-langserver",
            "filetypes": ["go"],
            "initializationOptions": {
                "gocodeCompletionEnabled": true,
                "diagnosticsEnabled": true,
                "lintTool": "golint"
            }
        }
    },
    "svelte.plugin.typescript.diagnostics.enable": false
}
